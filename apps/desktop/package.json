{
  "name": "wispyr-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Wispyr — The open-source AI agent that non-developers actually finish installing.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win",
    "build:portable": "electron-vite build && electron-builder --win portable",
    "build:installer": "electron-vite build && electron-builder --win nsis",
    "preview": "electron-vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "rm -rf out dist"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "docx": "^9.6.1",
    "electron-store": "^8.2.0",
    "exceljs": "^4.4.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.12.0",
    "pdfkit": "^0.18.0",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.1.0",
    "typescript": "^5.7.0"
  }
